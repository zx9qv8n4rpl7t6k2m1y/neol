<script>
var CDN      = "https://cdn.jsdelivr.net/gh/gru6nny/neol@main/Build";   /* <-- degistir */
var buildUrl = CDN;
var loaderUrl = buildUrl + "/base-artillery-defense.loader.js";
var config = {
  dataUrl:            buildUrl + "/base-artillery-defense.data.unityweb",
  frameworkUrl:       buildUrl + "/base-artillery-defense.framework.js.unityweb",
  codeUrl:            buildUrl + "/base-artillery-defense.wasm.unityweb",
  streamingAssetsUrl: "StreamingAssets",
  companyName:        "AO.games",
  productName:        "game",
  productVersion:     "1.0.0"
};

var container        = document.querySelector("#unity-container");
var canvas           = document.querySelector("#unity-canvas");
var loadingCover     = document.querySelector("#loading-cover");
var progressBarEmpty = document.querySelector("#unity-progress-bar-empty");
var progressBarFull  = document.querySelector("#unity-progress-bar-full");

if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent))
  container.className = "unity-mobile";

canvas.style.background = "url('https://cdn.jsdelivr.net/gh/gru6nny/neol@main/background.jpg') center / cover";
loadingCover.style.display = "";

canvas.addEventListener("touchstart",  function(){ window.focus(); });
canvas.addEventListener("pointerdown", function(){ window.focus(); });

var player          = null;
var leaderboard     = null;
var leaderboardInited = false;
var myGameInstance  = null;
var payments        = null;
var promptCanShow   = false;
var reviewCanShow   = false;
var initSDK         = false;
var initGame        = false;
var photoSizeForInit;
var scopesForInit;
var firstAd         = true;
var nowFullAdOpen   = false;

window.addEventListener('beforeunload', function(){
  if (myGameInstance != null)
    myGameInstance.SendMessage('YandexGame', 'SaveProgress');
});
window.onfocus = function(){
  if (myGameInstance != null && initGame){
    myGameInstance.SendMessage('AudioProducer', 'OnWindowFocus');
    console.log('window focus js');
  }
};
window.onblur = function(){
  if (myGameInstance != null && initGame){
    myGameInstance.SendMessage('AudioProducer', 'OnWindowBlur');
    console.log('window blur js');
  }
};

/* ── LOADER ───────────────────────────────────────────────── */
var script = document.createElement("script");
script.src = loaderUrl;
script.onload = function() {
  createUnityInstance(canvas, config, function(progress){
    progressBarFull.style.width = (100 * progress) + '%';
  }).then(function(unityInstance){
    loadingCover.style.display = "none";
    progressBarEmpty.style.display = "";
    myGameInstance = unityInstance;
  }).catch(function(message){ alert(message); });
};

/* ── SDK INIT ─────────────────────────────────────────────── */
YaGames.init().then(function(ysdk){
  console.log('Init Yandex SDK');
  window.ysdk = ysdk;
  initSDK = true;
  InitPayments();

  ysdk.getLeaderboards().then(function(_lb){
    leaderboard = _lb;
    leaderboardInited = true;
  });

  try {
    ysdk.shortcut.canShowPrompt().then(function(prompt){
      if (prompt.canShow) promptCanShow = true;
    });
  } catch(e){ console.error('CRASH canShowPrompt:', e.message); }

  try {
    ysdk.feedback.canReview().then(function(d){
      if (d.value) reviewCanShow = true;
      else console.log('reviewCanShow = false', d.reason);
    });
  } catch(e){ console.error('CRASH canShowFeedback:', e.message); }

  FullAdShow();
});

function InitSDK(photoSize, scopes) {
  console.log('Init GAME');
  initGame = true;
  photoSizeForInit = photoSize;
  scopesForInit = scopes;
  if (initSDK) InitPlayer(photoSize, scopes);
  if (nowFullAdOpen) myGameInstance.SendMessage('YandexGame', 'OpenFullAd');
}

function NotAuthorized() {
  try {
    console.log('Authorized failed');
    myGameInstance.SendMessage('YandexGame', 'SetInitializationSDK', JSON.stringify({
      playerAuth: "rejected", playerName: "unauthorized",
      playerId: "unauthorized", playerPhoto: "null"
    }));
  } catch(e){ console.error('CRASH Not Authorized:', e.message); }
}

function RequestServerTime() {
  try {
    if (initGame){
      var time = ysdk.serverTime();
      myGameInstance.SendMessage('ServerTimeHandler', 'ReceiveTimeMs', time.toString());
    }
  } catch(e){ console.error('crash server time request:', e.message); }
}

function RequestWebCursorLockstate() {
  try {
    if (initGame){
      if (document.pointerLockElement === canvas)
        myGameInstance.SendMessage('WebCursorLockFixer', 'CursorIsLocked');
      else
        myGameInstance.SendMessage('WebCursorLockFixer', 'CursorIsUnlocked');
    }
  } catch(e){ console.error('crash cursor lockstate:', e.message); }
}

function InitPlayer(photoSize, _scopes) {
  try {
    return ysdk.getPlayer({ scopes: _scopes }).then(function(_player){
      player = _player;
      var playerName  = player.getName();
      var playerPhoto = player.getPhoto(photoSize);
      if (!_scopes){ playerName = "anonymous"; playerPhoto = "null"; }
      if (player.getMode() === 'lite'){
        console.log('Not Authorized'); NotAuthorized();
      } else {
        myGameInstance.SendMessage('YandexGame', 'SetInitializationSDK', JSON.stringify({
          playerAuth: "resolved", playerName: playerName,
          playerId: player.getUniqueID(), playerPhoto: playerPhoto
        }));
        window.focus();
      }
    }).catch(function(e){ console.error('Authorized err:', e.message); NotAuthorized(); });
  } catch(e){ console.error('CRASH init Player:', e.message); window.focus(); }
}

function OpenAuthDialog(photoSize, scopes) {
  try {
    ysdk.auth.openAuthDialog().then(function(){
      InitPlayer(photoSize, scopes);
    }).catch(function(){ InitSDK(photoSize, scopes); });
  } catch(e){ console.log('CRASH Open Auth Dialog:', e.message); }
}

function FullAdShow() {
  try {
    if (!nowFullAdOpen){
      window.ysdk.adv.showFullscreenAdv({ callbacks: {
        onOpen: function(){
          nowFullAdOpen = true; console.log('Open Fullscreen Ad');
          if (initGame) myGameInstance.SendMessage('YandexGame', 'OpenFullAd');
        },
        onClose: function(wasShown){
          nowFullAdOpen = false;
          if (initGame){
            myGameInstance.SendMessage('YandexGame', 'CloseFullAd', wasShown ? 'true' : 'false');
            console.log('Close Fullscreen Ad. WasShown:', wasShown);
          }
          window.focus();
        },
        onError: function(error){
          nowFullAdOpen = false; console.error('Error Fullscreen Ad', error);
          if (myGameInstance) myGameInstance.SendMessage('YandexGame', 'ErrorFullAd');
          window.focus();
        }
      }});
    }
  } catch(e){ console.error('CRASH FullAd Show:', e.message); }
}

function RewardedShow(id) {
  try {
    window.ysdk.adv.showRewardedVideo({ callbacks: {
      onOpen:     function(){ console.log('Opened Video Ad. Id:'+id); myGameInstance.SendMessage('YandexGame','OpenVideo'); },
      onClose:    function(){ console.log('Closed Video Ad. Id:'+id);  myGameInstance.SendMessage('YandexGame','CloseVideo'); window.focus(); },
      onRewarded: function(){ console.log('Reward Video Ad. Id:'+id);  myGameInstance.SendMessage('YandexGame','RewardVideo',id); },
      onError:    function(e){ console.error('Error Video Ad. Id:'+id,e); myGameInstance.SendMessage('YandexGame','ErrorVideo'); }
    }});
  } catch(err){ console.error('CRASH Rewarded Video Ad Show:', err.message); }
}

function StickyAdActivity(show) {
  try {
    ysdk.adv.getBannerAdvStatus().then(function(d){
      if (d.stickyAdvIsShowing){ if (!show) ysdk.adv.hideBannerAdv(); }
      else if (d.reason) console.log('Sticky ad not shown. Reason:', d.reason);
      else if (show) ysdk.adv.showBannerAdv();
    });
  } catch(e){ console.error('CRASH Sticky Activity:', e.message); }
}

function InitPayments() {
  try {
    ysdk.getPayments().then(function(_payments){
      console.log('Purchases are available'); payments = _payments;
    }).catch(function(e){ console.log('Purchases not available', e.message); });
  } catch(e){ console.error('CRASH Init Payments:', e.message); }
}

function BuyPayments(id) {
  try {
    if (payments != null){
      payments.purchase(id).then(function(){
        console.log('Purchase Success'); ConsumePurchase(id); window.focus();
      }).catch(function(e){
        console.error('Purchase Failed', e.message);
        myGameInstance.SendMessage('YandexGame','OnPurchaseFailed',id); window.focus();
      });
    } else { console.log('Payments == null'); }
  } catch(e){ console.error('CRASH Buy Payments:', e.message); window.focus(); }
}

function GetPayments() {
  try {
    if (payments != null){
      payments.getCatalog().then(function(products){
        payments.getPurchases().then(function(purchases){
          var productID=[],title=[],description=[],imageURI=[],priceValue=[],consumed=[],
              priceWithCode=[],priceCurrencyImageURL=[];
          for(var i=0;i<products.length;i++){
            productID[i]=products[i].id; title[i]=products[i].title;
            description[i]=products[i].description; imageURI[i]=products[i].imageURI;
            priceValue[i]=products[i].priceValue; priceWithCode[i]=products[i].price;
            priceCurrencyImageURL[i]=products[i].getPriceCurrencyImage();
            consumed[i]=true;
            for(var i2=0;i2<purchases.length;i2++){
              if(purchases[i2].productID===productID[i]){consumed[i]=false;break;}
            }
          }
          myGameInstance.SendMessage('YandexGame','PaymentsEntries',JSON.stringify({
            id:productID,title:title,description:description,imageURI:imageURI,
            priceValue:priceValue,consumed:consumed,priceWithCode:priceWithCode,
            priceCurrencyImageURL:priceCurrencyImageURL
          }));
        });
      });
    } else { console.log('Get Payments: payments == null'); }
  } catch(e){ console.error('CRASH Get Payments:', e.message); }
}

function GetProductsList() {
  console.log('GetProductsList');
  try {
    if (payments != null){
      payments.getCatalog().then(function(products){
        var productID=[],title=[],description=[],imageURI=[],priceValue=[],consumed=[],
            priceWithCode=[],priceCurrencyCode=[],priceCurrencyImageURL=[];
        for(var i=0;i<products.length;i++){
          productID[i]=products[i].id; title[i]=products[i].title;
          description[i]=products[i].description; imageURI[i]=products[i].imageURI;
          priceValue[i]=products[i].priceValue; priceWithCode[i]=products[i].price;
          priceCurrencyCode[i]=products[i].priceCurrencyCode;
          priceCurrencyImageURL[i]=products[i].getPriceCurrencyImage();
          consumed[i]=false;
        }
        myGameInstance.SendMessage('PaymentsReceiver','GetProductsListCallback',JSON.stringify({
          id:productID,title:title,description:description,imageURI:imageURI,
          priceValue:priceValue,consumed:consumed,priceWithCode:priceWithCode,
          priceCurrencyCode:priceCurrencyCode,priceCurrencyImageURL:priceCurrencyImageURL
        }));
      });
    } else { console.log('Get Payments: payments == null'); }
  } catch(e){ console.error('CRASH Get Payments:', e.message); }
}

function ConsumePurchase(id) {
  try {
    if (payments != null){
      payments.getPurchases().then(function(purchases){
        for(var i=0;i<purchases.length;i++){
          if(purchases[i].productID===id){
            payments.consumePurchase(purchases[i].purchaseToken);
            myGameInstance.SendMessage('YandexGame','OnPurchaseSuccess',id);
          }
        }
      });
    } else { console.log('Consume purchase: payments null'); }
  } catch(e){ console.error('CRASH Consume Purchase:', e.message); }
}

function ConsumePurchases() {
  try {
    if (payments != null){
      payments.getPurchases().then(function(purchases){
        console.log('Unprocessed purchases:', purchases.length);
        for(var i=0;i<purchases.length;i++){
          payments.consumePurchase(purchases[i].purchaseToken);
          myGameInstance.SendMessage('YandexGame','OnPurchaseSuccess',purchases[i].productID);
        }
      });
    } else { console.log('Consume purchases: payments null'); }
  } catch(e){ console.error('CRASH Consume purchases:', e.message); }
}

function SaveCloud(jsonData, flush) {
  try {
    console.log('save');
    player.setData({ saves: [jsonData] }, flush);
  } catch(e){ console.error('CRASH Save Cloud:', e.message); }
}

function LoadCloud() {
  try {
    player.getData(["saves"]).then(function(data){
      if (data.saves)
        myGameInstance.SendMessage('YandexGame','SetLoadSaves',JSON.stringify(data.saves));
      else
        myGameInstance.SendMessage('YandexGame','SetLoadSaves','noData');
    }).catch(function(){
      console.error('getData Error!');
      myGameInstance.SendMessage('YandexGame','SetLoadSaves','noData');
    });
  } catch(e){
    console.error('CRASH Load saves Cloud:', e.message);
    myGameInstance.SendMessage('YandexGame','SetLoadSaves','noData');
  }
}

function GetBannerActivityState() {
  try {
    ysdk.adv.getBannerAdvStatus().then(function(d){
      myGameInstance.SendMessage('PaymentsReceiver','ReceiveBannerActivityState',
        d.stickyAdvIsShowing ? 'true' : 'false');
    });
  } catch(e){ console.error('CRASH get banner activity state:', e.message); }
}

function SetLeaderboardScore(score) {
  console.log('SetLeaderboardScore ' + score);
  try {
    if (leaderboardInited){
      leaderboard.setLeaderboardScore('MainScoreLeaderboard', score);
    } else {
      ysdk.getLeaderboards().then(function(l){
        l.setLeaderboardScore('MainScoreLeaderboard', score);
      });
    }
  } catch(e){ console.error('CRASH Set Leaderboard Scores:', e.message); }
}

function LanguageRequest() {
  try {
    console.log('LanguageRequest ' + ysdk.environment.i18n.lang);
    myGameInstance.SendMessage('YandexGame','SetLanguage',ysdk.environment.i18n.lang);
  } catch(e){ console.error('CRASH Language Request:', e.message); }
}

function RequestingEnvironmentData() {
  try {
    myGameInstance.SendMessage('YandexGame','SetEnvironmentData',JSON.stringify({
      language:      ysdk.environment.i18n.lang,
      domain:        ysdk.environment.i18n.tld,
      deviceType:    ysdk.deviceInfo.type,
      isMobile:      ysdk.deviceInfo.isMobile(),
      isDesktop:     ysdk.deviceInfo.isDesktop(),
      isTablet:      ysdk.deviceInfo.isTablet(),
      isTV:          ysdk.deviceInfo.isTV(),
      appID:         ysdk.environment.app.id,
      browserLang:   ysdk.environment.browser.lang,
      payload:       ysdk.environment.payload,
      promptCanShow: promptCanShow,
      reviewCanShow: reviewCanShow
    }));
  } catch(e){ console.error('CRASH Requesting Environment Data:', e.message); }
}

function Review() {
  try {
    ysdk.feedback.canReview().then(function(d){
      if (d.value){
        ysdk.feedback.requestReview().then(function(r){
          console.log('feedbackSent', r.feedbackSent);
          myGameInstance.SendMessage('YandexGame','ReviewSent',r.feedbackSent?'true':'false');
          window.focus();
        });
      } else { console.log('Review can show = false', d.reason); window.focus(); }
    });
  } catch(e){ console.error('CRASH Review:', e.message); window.focus(); }
}

function PromptShow() {
  try {
    ysdk.shortcut.showPrompt().then(function(result){
      console.log('Shortcut created?:', result);
      if (result.outcome === 'accepted'){
        console.log('Prompt Success');
        myGameInstance.SendMessage('YandexGame','OnPromptSuccess');
      } else {
        myGameInstance.SendMessage('YandexGame','OnPromptFail');
      }
      window.focus();
    });
  } catch(e){ console.error('CRASH Prompt Show:', e.message); window.focus(); }
}

document.body.appendChild(script);
</script>
</body>
</html>



