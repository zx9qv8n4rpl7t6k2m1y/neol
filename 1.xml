<!DOCTYPE html>
<html lang="en-us">
<head>
<meta charset="utf-8"/>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<style>
  html{overflow:hidden;-webkit-touch-callout:none;-webkit-user-select:none;
    -moz-user-select:none;-ms-user-select:none;user-select:none;
    -khtml-user-select:none;-o-user-select:none;cursor:default;}
</style>
<link rel="shortcut icon" href="https://cdn.jsdelivr.net/gh/gru6nny/neol@main/TemplateData/favicon.ico"/>
